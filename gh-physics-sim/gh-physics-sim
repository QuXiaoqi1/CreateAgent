#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0-dev"
DEFAULT_WORKSPACE=".physics-sim"

usage() {
  cat <<'EOF'
gh physics-sim - local Physics Simulation Agent CLI

Usage:
  gh physics-sim --help
  gh physics-sim version
  gh physics-sim doctor
  gh physics-sim init [--workspace .physics-sim]
  gh physics-sim new "simulate airflow through a 2D pipe" [--case-name pipe-demo] [--workspace .physics-sim]
  gh physics-sim add-file ./diagram.png [--workspace .physics-sim]
  gh physics-sim add-table ./params.xlsx [--workspace .physics-sim]
  gh physics-sim draft [--workspace .physics-sim]
  gh physics-sim validate [--workspace .physics-sim]
  gh physics-sim generate [--workspace .physics-sim]
  gh physics-sim run [--mode mock|auto] [--workspace .physics-sim]
  gh physics-sim status [--workspace .physics-sim]
  gh physics-sim report [--workspace .physics-sim]
  gh physics-sim package [--workspace .physics-sim]

This is an MVP GitHub CLI extension. The workflow is local-first, delegates
simulation stages to the platform core, and does not require GitHub auth.
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

script_dir() {
  cd "$(dirname "${BASH_SOURCE[0]}")" && pwd
}

bridge() {
  local root
  root="${PHYSICS_SIM_AGENT_ROOT:-$(script_dir)/../physics-simulation-agent}"
  PHYSICS_SIM_AGENT_ROOT="$root" python3 "$(script_dir)/lib/physics_sim_cli.py" "$@"
}

workspace_from_args() {
  local workspace="$DEFAULT_WORKSPACE"
  local args=("$@")
  local i=0
  while [ "$i" -lt "${#args[@]}" ]; do
    if [ "${args[$i]}" = "--workspace" ]; then
      i=$((i + 1))
      [ "$i" -lt "${#args[@]}" ] || die "--workspace requires a value"
      workspace="${args[$i]}"
    fi
    i=$((i + 1))
  done
  printf '%s\n' "$workspace"
}

cmd_doctor() {
  local workspace
  workspace="$(workspace_from_args "$@")"

  printf 'Physics Simulation Agent doctor\n'
  printf 'version: %s\n' "$VERSION"
  printf 'cwd: %s\n' "$(pwd)"

  if command -v gh >/dev/null 2>&1; then
    printf 'gh: %s\n' "$(gh --version | head -n 1)"
  else
    printf 'gh: missing\n'
  fi

  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'git: inside work tree\n'
    printf 'git root: %s\n' "$(git rev-parse --show-toplevel 2>/dev/null || true)"
  else
    printf 'git: not inside work tree\n'
  fi

  if [ -d "$workspace" ]; then
    printf 'workspace: %s (exists)\n' "$workspace"
  else
    printf 'workspace: %s (not initialized)\n' "$workspace"
  fi

  if [ -w "$(dirname "$workspace")" ]; then
    printf 'workspace parent writable: yes\n'
  else
    printf 'workspace parent writable: no\n'
  fi

  if command -v blockMesh >/dev/null 2>&1 || command -v simpleFoam >/dev/null 2>&1 || command -v foamRun >/dev/null 2>&1; then
    printf 'OpenFOAM: available\n'
  else
    printf 'OpenFOAM: not found\n'
  fi

  if command -v docker >/dev/null 2>&1; then
    printf 'Docker: available\n'
  else
    printf 'Docker: not found\n'
  fi
}

cmd_stage() {
  local stage="$1"
  shift
  bridge "$stage" "$@"
}

main() {
  local cmd="${1:-help}"
  if [ "$#" -gt 0 ]; then
    shift
  fi

  case "$cmd" in
    -h|--help|help)
      usage
      ;;
    version)
      printf 'gh-physics-sim %s\n' "$VERSION"
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    init|new|add-file|add-table|status|draft|validate|generate|run|report|package)
      cmd_stage "$cmd" "$@"
      ;;
    *)
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
